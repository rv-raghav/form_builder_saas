# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/form_builder

# API server
PORT=8000
NODE_ENV=development
BASE_URL=http://localhost:8000

# Auth
SESSION_SECRET=change-me-to-a-long-random-string
CSRF_SECRET=change-me-to-another-long-random-string
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=localhost
APP_URL=http://localhost:3000
API_URL=http://localhost:8000

# Google OAuth (optional)
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_OAUTH_REDIRECT_URI=

# Web app (Vite)
VITE_API_BASE_URL=
VITE_DEV_BACKEND_URL=http://localhost:8000

# Email (optional — reset links logged to console if unset; Phase 5 new-response mails too)
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASS=
EMAIL_FROM=noreply@chaiforms.local
