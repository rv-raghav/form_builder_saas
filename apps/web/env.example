# 1. API CONFIGURATION (leave empty for development)
VITE_API_BASE_URL=

# 2. DEVELOPMENT SETTINGS
VITE_DEV_BACKEND_URL=http://localhost:8000

# 3. APP CONFIGURATION (optional)
# VITE_APP_NAME=Creative Dashboard
# VITE_ENABLE_ANALYTICS=false
